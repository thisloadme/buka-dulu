PORT=8080
DATABASE_URL=sqlite://./data/bukadulu.db
JWT_SECRET=change-this-in-production
JWT_EXPIRY_HOURS=24

# ─── LLM Multi-Provider Configuration ─────────────────
# Provider options:
#   openai      → https://api.openai.com/v1
#   anthropic   → https://api.anthropic.com/v1
#   openrouter  → https://openrouter.ai/api/v1
#   groq        → https://api.groq.com/openai/v1
#   together    → https://api.together.xyz/v1
#   opencode    → http://localhost:8080/v1
#   ollama      → http://localhost:11434 (uses /api/chat endpoint)
#   mock        → no AI needed, returns dummy data
#
# Custom provider: set LLM_PROVIDER then fill URL + key
#   LLM_PROVIDER=custom
#   LLM_BASE_URL=https://your-llm-server.com/v1
#   LLM_API_KEY=your-key
#   LLM_MODEL=your-model
#
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ─── SMTP / Email (OTP Verification) ─────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# SMTP_FROM=noreply@bukadulu.id
# OTP_EXPIRY_MINUTES=10

# ─── Storage ─────────────────
STORAGE_TYPE=local
STORAGE_PATH=./storage/evidence
